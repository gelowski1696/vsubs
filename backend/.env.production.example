NODE_ENV=production
PORT=3003
DATABASE_URL="file:/data/subman.db"

JWT_ACCESS_SECRET=replace-with-strong-random-access-secret
JWT_REFRESH_SECRET=replace-with-strong-random-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
MOBILE_UPDATE_TOKEN_SECRET=replace-with-strong-random-mobile-update-secret
MOBILE_UPDATE_ALLOW_UNSIGNED_DOWNLOADS=false

# Temporary no-domain mode for VPS bring-up. Replace with explicit origins later.
CORS_ORIGINS=*
USE_HTTPS_SECURITY_HEADERS=false

# Set true only on first boot when you need initial data
SEED_ON_BOOT=false
